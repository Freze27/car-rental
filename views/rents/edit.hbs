<h1>Edit Rent #{{rent.id}}</h1>

<div class="form-card">
  <form method="POST" action="/rents/{{rent.id}}/update">
    <div class="form-group">
      <label class="form-label">Total Amount ($)</label>
      <input type="number" name="totalAmount" class="form-input" value="{{rent.totalAmount}}" required>
    </div>
    <div class="form-group">
      <label class="form-label">Start Date</label>
      <input type="date" name="startDate" class="form-input" value="{{rent.startDate}}" required>
    </div>
    <div class="form-group">
      <label class="form-label">End Date</label>
      <input type="date" name="endDate" class="form-input" value="{{rent.endDate}}" required>
    </div>
    <div style="display:flex; gap:12px; margin-top:24px;">
      <a href="/rents" class="btn-admin-secondary">Cancel</a>
      <button type="submit" class="btn-admin-primary">Save</button>
    </div>
  </form>
</div>
