<div style="padding: 32px; max-width: 900px; margin: 0 auto;">
  <h1 style="font-size: 28px; font-weight: 700; color: #f9fafb; margin-bottom: 24px;">Profile</h1>

  {{#if user}}

  <div style="background: #1f2937; border-radius: 12px; padding: 32px; margin-bottom: 24px;">
    <img src="/assets/nav-avatar-Cjxu169C.png" alt="Avatar" style="width: 96px; height: 96px; border-radius: 50%; object-fit: cover; margin-bottom: 16px;" />
    <div style="display: flex; flex-direction: column; gap: 16px; margin-top: 16px;">
      <div>
        <div style="font-size: 12px; color: #6b7280; margin-bottom: 4px;">Display Name</div>
        <div style="font-size: 18px; font-weight: 600; color: #f9fafb;">{{user.displayName}}</div>
      </div>
      <div>
        <div style="font-size: 12px; color: #6b7280; margin-bottom: 4px;">First Name</div>
        <div style="font-size: 18px; font-weight: 600; color: #f9fafb;">{{user.firstName}}</div>
      </div>
      <div>
        <div style="font-size: 12px; color: #6b7280; margin-bottom: 4px;">Last Name</div>
        <div style="font-size: 18px; font-weight: 600; color: #f9fafb;">{{user.lastName}}</div>
      </div>
      <div>
        <div style="font-size: 12px; color: #6b7280; margin-bottom: 4px;">Email</div>
        <div style="font-size: 18px; font-weight: 600; color: #f9fafb;">{{user.email}}</div>
      </div>
    </div>
  </div>

  <div style="background: #1f2937; border-radius: 12px; padding: 32px;">
    <h2 style="font-size: 18px; font-weight: 600; color: #f9fafb; margin-bottom: 16px;">Rental History</h2>

    {{#if user.rents.length}}
    <div style="display: flex; flex-direction: column; gap: 12px;">
      {{#each user.rents}}
      <div style="display: flex; justify-content: space-between; align-items: center; padding: 12px 16px; background: #111827; border-radius: 10px; border: 1px solid #374151;">
        <div>
          <div style="font-weight: 600; color: #f9fafb;">{{this.car.title}}</div>
          <div style="font-size: 13px; color: #6b7280; margin-top: 4px;">{{this.startDate}} — {{this.endDate}}</div>
        </div>
        <div style="font-size: 14px; font-weight: 600; color: #3b82f6;">${{this.totalAmount}}</div>
      </div>
      {{/each}}
    </div>
    {{else}}
    <p style="color: #6b7280; font-size: 14px;">You have no rentals yet.</p>
    {{/if}}
  </div>

  {{else}}
  <div style="background: #1f2937; border-radius: 12px; padding: 32px;">
    <p style="color: #6b7280;">Please sign in to view your profile.</p>
  </div>
  {{/if}}
</div>
