<div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:24px;">
  <h1 style="margin:0;">Cars</h1>
  <a href="/cars/add" class="btn-admin-primary">Add Car</a>
</div>

<div style="display:grid; grid-template-columns:repeat(auto-fill, minmax(260px, 1fr)); gap:20px;">
  {{#each cars}}
  <div style="background:#1f2937; border-radius:12px; padding:20px; display:flex; flex-direction:column; gap:12px;">
    <div>
      <div style="font-size:16px; font-weight:700; color:#f9fafb;">{{this.title}}</div>
      <div style="font-size:13px; color:#6b7280;">{{this.category.name}} · {{this.transmissionType}}</div>
    </div>
    <img src="{{this.filePath}}" alt="{{this.title}}" style="height:100px; width:100%; object-fit:contain;" />
    <div style="font-size:15px; font-weight:700; color:#f9fafb;">${{this.dailyRate}} <span style="font-size:12px; color:#6b7280;">/ day</span></div>
    <div style="display:flex; gap:8px; align-items:center;">
      <a href="/cars/{{this.id}}" class="btn-admin-view">View</a>
      <a href="/cars/{{this.id}}/edit" class="btn-admin-edit">Edit</a>
      <form method="POST" action="/cars/{{this.id}}/delete" style="display:inline;">
        <button type="submit" class="btn-admin-danger">Delete</button>
      </form>
    </div>
  </div>
  {{/each}}
</div>
