<div style="padding: 32px; max-width: 1400px; margin: 0 auto;">
  <h1 style="font-size: 28px; font-weight: 700; color: #f9fafb; margin-bottom: 24px;">All Cars</h1>

  <div style="display: flex; gap: 24px; align-items: flex-start;">

    <!-- Filter Sidebar -->
    <div style="width: 280px; flex-shrink: 0; background: #1f2937; border-radius: 28px; padding: 24px; position: sticky; top: 24px;">
      <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 24px;">
        <h3 style="font-size: 16px; font-weight: 700; color: #f9fafb; text-transform: uppercase; letter-spacing: 0.05em;">Search Filters</h3>
        <span style="font-size: 11px; color: #6b7280; text-transform: uppercase; letter-spacing: 0.2em;">Cars</span>
      </div>

      <!-- Type filter -->
      <div style="background: #111827; border-radius: 16px; padding: 16px; margin-bottom: 16px;">
        <h4 style="font-size: 11px; font-weight: 600; color: #6b7280; text-transform: uppercase; letter-spacing: 0.3em; margin-bottom: 12px;">Type</h4>
        {{#each categories}}
        <label style="display: flex; align-items: center; gap: 10px; padding: 8px 12px; border-radius: 12px; cursor: pointer; margin-bottom: 4px; background: #1f2937;">
          <input type="checkbox" value="{{this.name}}" onchange="applyFilters()" class="type-filter" style="width:16px; height:16px; accent-color: #3b82f6;" />
          <span style="font-size: 14px; color: #d1d5db;">{{this.name}}</span>
        </label>
        {{/each}}
      </div>

      <!-- Max Price -->
      <div style="background: #111827; border-radius: 16px; padding: 16px; margin-bottom: 16px;">
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 12px;">
          <h4 style="font-size: 11px; font-weight: 600; color: #6b7280; text-transform: uppercase; letter-spacing: 0.25em;">Max Price</h4>
          <span id="priceDisplay" style="font-size: 16px; color: #f9fafb; font-weight: 600;">$300</span>
        </div>
        <input type="range" id="maxPrice" min="0" max="300" step="5" value="300" oninput="updatePrice(this.value); applyFilters()"
          class="range-slider" />
        <p style="font-size: 11px; color: #6b7280; margin-top: 8px;">Showing cars up to $<span id="priceLabel">300</span>/day</p>
      </div>

      <!-- Horse Power -->
      <div style="background: #111827; border-radius: 16px; padding: 16px;">
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 12px;">
          <h4 style="font-size: 11px; font-weight: 600; color: #6b7280; text-transform: uppercase; letter-spacing: 0.25em;">Horse Power</h4>
          <span id="hpDisplay" style="font-size: 14px; color: #f9fafb; font-weight: 600;">0–1000 HP</span>
        </div>
        <input type="range" id="minHp" min="0" max="1000" step="10" value="0" oninput="updateHp(); applyFilters()"
          class="range-slider" style="margin-bottom: 8px;" />
        <input type="range" id="maxHp" min="0" max="1000" step="10" value="1000" oninput="updateHp(); applyFilters()"
          class="range-slider" />
        <p style="font-size: 11px; color: #6b7280; margin-top: 8px;">Showing <span id="hpLabel">0–1000</span> HP</p>
      </div>
    </div>

    <!-- Cars Grid -->
    <div style="flex: 1; min-width: 0;">
      <div id="cars-grid" style="display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); gap: 20px;">
        {{#each cars}}
        <div class="car-item"
          data-category="{{this.category.name}}"
          data-price="{{this.dailyRate}}"
          data-hp="{{this.horsePower}}">
          {{> car-card}}
        </div>
        {{/each}}
      </div>

      <div id="no-results" style="display:none; text-align:center; padding: 48px; background: #1f2937; border-radius: 16px; border: 1px dashed #374151;">
        <p style="font-size: 16px; font-weight: 600; color: #f9fafb; margin-bottom: 8px;">No cars match the filters</p>
        <p style="font-size: 13px; color: #6b7280;">Try adjusting the filters to see more results.</p>
      </div>
    </div>

  </div>
</div>

<script>
function updatePrice(val) {
  document.getElementById('priceDisplay').textContent = '$' + val;
  document.getElementById('priceLabel').textContent = val;
}

function updateHp() {
  const min = document.getElementById('minHp').value;
  const max = document.getElementById('maxHp').value;
  document.getElementById('hpDisplay').textContent = min + '–' + max + ' HP';
  document.getElementById('hpLabel').textContent = min + '–' + max;
}

function applyFilters() {
  const selectedTypes = [...document.querySelectorAll('.type-filter:checked')].map(cb => cb.value);
  const maxPrice = parseInt(document.getElementById('maxPrice').value);
  const minHp = parseInt(document.getElementById('minHp').value);
  const maxHp = parseInt(document.getElementById('maxHp').value);

  let visible = 0;
  document.querySelectorAll('.car-item').forEach(item => {
    const cat = item.dataset.category;
    const price = parseFloat(item.dataset.price);
    const hp = parseInt(item.dataset.hp);

    const typeOk = selectedTypes.length === 0 || selectedTypes.includes(cat);
    const priceOk = price <= maxPrice;
    const hpOk = hp >= minHp && hp <= maxHp;

    if (typeOk && priceOk && hpOk) {
      item.style.display = 'block';
      visible++;
    } else {
      item.style.display = 'none';
    }
  });

  document.getElementById('no-results').style.display = visible === 0 ? 'block' : 'none';
}
</script>

<style>
  .range-slider {
    width: 100%;
    appearance: none;
    -webkit-appearance: none;
    height: 6px;
    border-radius: 4px;
    background: #374151;
    outline: none;
  }
  .range-slider::-webkit-slider-thumb {
    -webkit-appearance: none;
    width: 18px;
    height: 18px;
    border-radius: 50%;
    background: #3b82f6;
    cursor: pointer;
    border: 2px solid #111827;
  }
  .range-slider::-moz-range-thumb {
    width: 18px;
    height: 18px;
    border-radius: 50%;
    background: #3b82f6;
    cursor: pointer;
    border: 2px solid #111827;
    box-sizing: border-box;
  }
  .range-slider::-webkit-slider-runnable-track {
    height: 6px;
    border-radius: 4px;
    background: #374151;
  }
  .range-slider::-moz-range-track {
    height: 6px;
    border-radius: 4px;
    background: #374151;
  }
</style>
